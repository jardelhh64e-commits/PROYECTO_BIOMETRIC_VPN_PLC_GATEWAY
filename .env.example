# Copia este archivo como .env en la misma carpeta y completa los valores.
# El .env NUNCA se sube al repo (está en .gitignore).
#
# Genera una clave segura con:
#   openssl rand -hex 32

# Clave secreta compartida entre el cliente y el servidor
ZT_TOKEN=pon_aqui_tu_clave_secreta

# IP ZeroTier de la Raspberry Pi (servidor)
ZT_HOST=10.x.x.x

# Puerto del servidor
ZT_PORT=8088
